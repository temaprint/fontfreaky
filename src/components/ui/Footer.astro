---
import { Image } from "astro:assets";
import Logo from "public/Logo.svg";


const links = [
  { name: "Blog", href: "#Home" },
];
---

<section class="sm:px-5">
  <div class="w-full max-w-[1240px] mx-auto">
    <div
      class="px-[15px] bg-dark text-gray py-[55px] lg:px-[60px] sm:rounded-t-[45px]"
    >
      <div>
        <div
          class="flex flex-col lg:flex-row gap-7 items-center justify-between"
        >
          <picture>
            <a href="#home">
              <Image src={Logo} alt="Logo for Kreatif Brand" />
            </a>
          </picture>
        </div>
      </div>

      <div class="h-[1px] bg-gray mb-5"></div>
      <div
        class="flex flex-col lg:flex-row h-20 justify-center mt-4 text-center md:justify-between md:mt-0"
      >
        <span
          >2024 <a
            class="underline"
            target="_blank"
            href="https://astro.build">Astro</a
          > by 
          <a 
          class="underline"
          target="_blank"
          href="https://manulthanura.com">Manul</a
          ></span
        >&nbsp
        <span>

          <a
            href="https://artemkan.com/"
            target="_blank"
            class="underline">t3ma</a
          >
          <span> &</span>
          <a
            class="underline"
            href="https://creativecommons.org/licenses/by/4.0/"
            target="_blank">Licence</a
          >
        </span>
      </div>
    </div>
  </div>
</section>
