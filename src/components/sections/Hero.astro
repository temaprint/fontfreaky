---
import { Image } from "astro:assets";
import HeroIlust from "public/_image.svg";
---

<section id="home" class="px-4 py-16 md:py-24 md:px-8 max-w-5xl mx-auto">
  <div class="flex flex-col-reverse md:flex-row items-center gap-8 md:gap-12">
    <!-- Text content -->
    <div class="md:w-7/12 space-y-6">
      <div class="inline-block bg-hotpink/20 border border-hotpink px-2 py-0.5">
        <span class="font-pixel text-[0.5rem] text-hotpink">v1.0 ★ FREE DOWNLOAD</span>
      </div>

      <h1 class="font-pixel text-xl md:text-2xl lg:text-3xl text-lime glow-lime leading-relaxed">
        MAKE YOUR<br>TEXT <span class="text-hotpink glow-pink">FREAKY</span>
      </h1>

      <p class="text-cyan text-lg leading-relaxed">
        Freaky Font is a bold script typeface inspired by <span class="text-lime">Math Bold Script</span> Unicode characters.
        Now available as a real downloadable font in TTF and SVG formats.
      </p>

      <div class="space-y-3 text-base">
        <div class="flex items-start gap-2">
          <span class="text-y2kyellow">▸</span>
          <span class="text-cyan/80">Works in Photoshop, Figma, Illustrator & more</span>
        </div>
        <div class="flex items-start gap-2">
          <span class="text-y2kyellow">▸</span>
          <span class="text-cyan/80">TTF + SVG formats included</span>
        </div>
        <div class="flex items-start gap-2">
          <span class="text-y2kyellow">▸</span>
          <span class="text-cyan/80">Free & open source under Creative Commons</span>
        </div>
        <div class="flex items-start gap-2">
          <span class="text-y2kyellow">▸</span>
          <span class="text-cyan/80">Or use the online converter — no install needed</span>
        </div>
      </div>

      <div class="flex flex-wrap gap-3 pt-2">
        <a href="https://freaky.allbestfonts.com/FreakyFont.zip" class="btn-y2k">
          ★ DOWNLOAD FONT ★
        </a>
        <a href="#converter" class="btn-y2k btn-y2k-pink">
          TRY ONLINE
        </a>
      </div>
    </div>

    <!-- Hero illustration -->
    <div class="md:w-5/12 relative">
      <div class="pixel-border p-2 bg-grid relative scanlines">
        <Image src={HeroIlust} alt="Freaky Font preview" loading="eager" />
        <span class="absolute -top-3 -right-3 font-pixel text-[0.5rem] bg-hotpink text-white px-1.5 py-0.5">NEW!</span>
      </div>
    </div>
  </div>
</section>
