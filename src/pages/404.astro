---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="404 — Page Not Found | Freaky Font"
  description="The page you're looking for doesn't exist."
  robots={true}
>
  <div class="flex flex-col items-center justify-center py-24 px-4 text-center">
    <div class="pixel-border p-6 bg-grid mb-8 relative scanlines">
      <span class="font-pixel text-6xl md:text-8xl text-hotpink glow-pink">404</span>
    </div>
    <h1 class="font-pixel text-sm md:text-base text-lime glow-lime mb-4">
      PAGE LOST IN CYBERSPACE
    </h1>
    <p class="text-cyan text-lg mb-8 max-w-md">
      The page you're looking for has drifted into the void. Maybe it never existed. Spooky.
    </p>
    <a href="/" class="btn-y2k">
      ★ GO HOME ★
    </a>
  </div>
</MainLayout>
